```gitignore
# =========================
# Node.js / React
# =========================
node_modules/
dist/
build/
.next/
expo-env.d.ts

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment Variables
.env
.env.*
!.env.example

# Package Manager
package-lock.json
yarn.lock
pnpm-lock.yaml

# =========================
# Python / FastAPI / AI
# =========================
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual Environment
venv/
.venv/
env/
ENV/

# Python Build
build/
dist/
*.egg-info/

# Jupyter / Colab
.ipynb_checkpoints/

# AI / Model Files
models/
checkpoints/
outputs/
runs/
wandb/
mlruns/
*.pt
*.pth
*.ckpt
*.safetensors
*.bin

# HuggingFace Cache
.cache/
huggingface/

# =========================
# VSCode / IDE
# =========================
.vscode/
.idea/

# =========================
# OS
# =========================
.DS_Store
Thumbs.db

# =========================
# Docker
# =========================
docker-data/
*.tar

# =========================
# Coverage / Testing
# =========================
coverage/
.pytest_cache/

# =========================
# Temporary Files
# =========================
tmp/
temp/
*.tmp

# =========================
# Firebase / Google
# =========================
google-services.json
GoogleService-Info.plist
serviceAccountKey.json

# =========================
# Secrets / Keys
# =========================
*.pem
*.key
*.crt
secrets/


# =============================
# raw data / csv / json / jsonl
# =============================

data/raw/*
data/processed/*
data/splits/*

!data/raw/.gitkeep
!data/processed/.gitkeep
!data/splits/.gitkeep
```


# =========================
# Unsloth / LoRA
